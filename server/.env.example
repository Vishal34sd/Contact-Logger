# Server
PORT=5000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/contact-logger

# JWT
JWT_SECRET=your-jwt-secret-min-32-chars-long-here
JWT_EXPIRES_IN=7d

# Client
CLIENT_URL=http://localhost:5173

# HubSpot OAuth
HUBSPOT_CLIENT_ID=your-hubspot-client-id
HUBSPOT_CLIENT_SECRET=your-hubspot-client-secret
HUBSPOT_REDIRECT_URI=http://localhost:5000/api/auth/hubspot/callback

# Encryption (64-char hex string for AES-256 — optional in development)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=
